<div class="max-w-3xl mx-auto p-4">
  <h1 class="text-2xl font-bold mb-4">Candidates Ranked</h1>

  <table class="min-w-full border">
    <thead>
    <tr class="bg-gray-100">
      <th class="px-4 py-2">Name</th>
      <th class="px-4 py-2">Skills</th>
      <th class="px-4 py-2">Experience</th>
      <th class="px-4 py-2">GitHub Score</th>
      <th class="px-4 py-2">Total Score</th>
      <th class="px-4 py-2">Actions</th>
    </tr>
    </thead>
    <tbody>
    <% @candidates.each do |c| %>
      <tr class="border-t">
        <td class="px-4 py-2"><%= c.name %></td>
        <td class="px-4 py-2"><%= c.skills&.select { |k,v| v==1 }&.keys&.join(", ") || "N/A" %></td>
        <td class="px-4 py-2"><%= c.experience || 0 %> yrs</td>
        <td class="px-4 py-2"><%= c.github_score || 0 %></td>
        <td class="px-4 py-2 font-bold"><%= c.total_score || 0 %></td>
        <td class="px-6 py-2 space-x-2">
          <%= link_to "Resume",
                      rails_blob_path(c.resume, disposition: "inline"),
                      target: "_blank",
                      class: "bg-blue-500 text-white px-4 py-2 rounded" if c.resume.attached? %>

          <%= button_to "Delete",
                        candidate_path(c),
                        method: :delete,
                        class: "bg-yello-500 text-black px-4 py-2 rounded",
                        onsubmit: "return confirm('Are you sure you want to delete this candidate?');" %>
        </td>


      </tr>
    <% end %>
    </tbody>
  </table>
</div>
